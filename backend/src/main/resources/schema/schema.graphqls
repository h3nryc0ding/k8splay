schema {
    query: Query
    mutation: Mutation
    subscription: Subscription
}

type Query {
    messages: [Message!]!
    currentUser: Authentication
}

type Mutation {
    messageSend(input: MessageInput!): Message!

    userAuthenticate(input: AuthenticationInput!): Authentication!
    userRegister(input: AuthenticationInput!): Authentication!
    userLogout: Boolean!
}

type Subscription {
    messageSent: Message!
}

# BEGIN: User
type Authentication {
    token: String!
    username: String!
    authorities: [String!]!
}

input AuthenticationInput {
    username: String!
    password: String!
}
# END: User

# BEGIN: Message
type Message {
    id: ID!
    text: String!
    creator: String!
    timestamp: String!
}

input MessageInput {
    text: String!
    creator: String!
}
# END: Message